{
  "private": true,
  "devDependencies": {
    "bats-support": "github:bats-core/bats-support",
    "bats-assert": "github:bats-core/bats-assert"
  },
  "scripts": {
    "test": "bats --pretty test/",
    "test:functional": "bash test/functional/docker-run.sh",
    "test:functional:analyse": "bash test/functional/analyse.sh",
